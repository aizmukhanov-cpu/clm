# Скопируйте этот файл в .env.local и заполните значения
# cp .env.example .env.local

# ── База данных ────────────────────────────────────────────
# Подключение через PgBouncer (transaction pooler, порт 6543)
DATABASE_URL=postgresql://user:password@host:6543/dbname?pgbouncer=true

# Прямое подключение для Prisma migrations и generate (порт 5432)
DIRECT_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────
# Любая случайная строка, минимум 32 символа
JWT_SECRET=replace-with-random-32-char-string

# ── Cron защита ───────────────────────────────────────────
# Bearer token для /api/cron/* эндпоинтов
CRON_SECRET=replace-with-random-string

# ── Telegram Bot (опционально) ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Webhook уведомления (опционально) ─────────────────────
NOTIFICATION_WEBHOOK_URL=
