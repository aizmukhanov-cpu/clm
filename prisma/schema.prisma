generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum CLMStage {
  ACQUIRE
  ONBOARD
  ACTIVATE
  GROW
  REACTIVATE
}

enum CLMCohort {
  NEVER_ACTIVE
  LOW_ACTIVE
  ACTIVE
  LAPSED
}

enum ClientType {
  YL
  IP
}

enum TeamType {
  VB
  B2B
  KM
  KAM
  BRANCH
}

enum UserRole {
  ADMIN        // Полный доступ + панель администратора
  DIRECTOR     // Read-only по всем командам + KPI
  ANALYST      // Read-only аналитик
  TEAM_LEAD    // Вся команда (все клиенты своей команды)
  SUPERVISOR   // Свои подчинённые (по supervisorId)
  SPECIALIST   // Только свои клиенты (бывший MANAGER)
  KAM          // Только свои KAM-клиенты (бывший KAM_ROLE)
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  WHATSAPP
  VISIT
}

enum TaskStatus {
  PENDING
  DONE
  OVERDUE
  ESCALATED
}

enum TaskPriority {
  P1
  P2
  P3
}

enum DealStatus {
  ACTIVE
  WON
  LOST
}

enum DealLostReason {
  PRICE           // Цена / тариф не устроил
  COMPETITOR      // Ушёл к конкуренту
  NO_NEED         // Нет потребности в продукте
  TIMING          // Не готов сейчас, вернётся позже
  NO_BUDGET       // Нет бюджета
  DOCS_MISSING    // Не хватает документов / не прошёл KYC
  AML_DECLINED    // Отказ по AML/compliance
  CONTACT_LOST    // Потеряли контакт (ghosting)
  OTHER           // Другое
}

enum KYCItemStatus {
  PENDING
  DONE
  N_A
}

// Сегментация клиентов по годовому обороту.
// Используется при автопередаче от охотников (B2B/KM) к фермерам.
enum ClientSizeCategory {
  SMALL    // B2B-сегмент: годовой GMV < 10 млн KGS → BRANCH
  MEDIUM   // KM-сегмент:  годовой GMV 10–100 млн KGS → VB
  LARGE    // KAM-сегмент: годовой GMV ≥ 100 млн KGS → KAM
}

// ─── Models ──────────────────────────────────────────────

model Branch {
  id                  String   @id @default(cuid())
  name                String
  region              String
  targetPct           Float    @default(60) @map("target_pct")
  marketCapacityYL    Int?     @map("market_capacity_yl")   // кол-во ЮЛ в регионе
  marketCapacityIP    Int?     @map("market_capacity_ip")   // кол-во ИП в регионе
  marketSharePct      Float?   @map("market_share_pct")     // текущая доля рынка %
  createdAt           DateTime @default(now()) @map("created_at")

  users          User[]
  clients        Client[]
  productTargets BranchProductTarget[]

  @@map("branches")
}

// Цели филиала по каждому продукту на месяц
model BranchProductTarget {
  id          String   @id @default(cuid())
  branchId    String   @map("branch_id")
  product     String   // product code (ссылается на products.code)
  targetCount Int      @map("target_count")
  year        Int
  month       Int      @default(1) // 1-12
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, product, year, month])
  @@map("branch_product_targets")
}

// Цели команды по каждому продукту на месяц (B2B | KM | KAM | VB | BRANCH)
model TeamProductTarget {
  id          String   @id @default(cuid())
  team        String   // B2B | KM | KAM | VB | BRANCH
  product     String   // product code
  targetCount Int      @map("target_count")
  year        Int
  month       Int      @default(1) // 1-12
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([team, product, year, month])
  @@map("team_product_targets")
}

// Каталог банковских продуктов (управляется через /admin/products)
model Product {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  icon      String   @default("📦")
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         UserRole
  team         TeamType
  branchId     String   @map("branch_id")
  passwordHash String   @map("password_hash")
  createdAt      DateTime @default(now()) @map("created_at")
  supervisorId   String?  @map("supervisor_id")  // для SUPERVISOR: кто является руководителем
  planMonthly         Int?      @map("plan_monthly")          // план новых клиентов в месяц
  telegramChatId      String?   @map("telegram_chat_id")       // персональный Telegram chat_id для алертов

  // ── Security ──────────────────────────────────────────────────────────────
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")           // брутфорс-блокировка до этого времени
  sessionVersion      Int       @default(0) @map("session_version") // инкрементируется при смене роли/пароля

  branch        Branch     @relation(fields: [branchId], references: [id])
  supervisor    User?      @relation("UserHierarchy", fields: [supervisorId], references: [id])
  subordinates  User[]     @relation("UserHierarchy")
  managedClients    Client[]   @relation("ClientManager")
  kamClients        Client[]   @relation("ClientKAM")
  activities        Activity[]
  tasks             Task[]
  deals             Deal[]
  changelogs        Changelog[]
  monthlySnapshots  ManagerMonthlySnapshot[]
  notifications     Notification[]

  @@map("users")
}

model Client {
  id               String     @id @default(cuid())
  inn              String     @unique
  name             String
  type             ClientType
  okved            String?
  accountOpenedAt  DateTime?  @map("account_opened_at")
  branchId         String     @map("branch_id")
  managerId        String?    @map("manager_id")
  kamId            String?    @map("kam_id")
  clmStage         CLMStage   @default(ACQUIRE) @map("clm_stage")
  clmCohort        CLMCohort          @default(NEVER_ACTIVE) @map("clm_cohort")
  sizeCategory     ClientSizeCategory? @map("size_category")   // вычисляется RFM-sync
  activatedAt      DateTime?           @map("activated_at")    // дата первого перехода в ACTIVATE
  handoffDoneAt    DateTime?           @map("handoff_done_at") // дата передачи фермеру; null = ещё не передан
  onboardedAt      DateTime?           @map("onboarded_at")   // дата входа в ONBOARD (для таймера D+N задач)
  firstTxnAt       DateTime?           @map("first_txn_at")   // дата первой транзакции (set once)
  daysSinceLastTxn Int                @default(0) @map("days_since_last_txn")
  txnCount30d      Int        @default(0) @map("txn_count_30d")
  gmv30d           Float      @default(0) @map("gmv_30d")
  productDepthPct  Float      @default(0) @map("product_depth_pct")
  isArchived       Boolean    @default(false) @map("is_archived")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  // Продуктовая карта
  hasMBusiness     Boolean @default(false) @map("has_mbusiness")
  hasMKassaPos     Boolean @default(false) @map("has_mkassa_pos")
  hasMKassaQr      Boolean @default(false) @map("has_mkassa_qr")
  hasSalaryProject Boolean @default(false) @map("has_salary_project")
  hasAcquiring     Boolean @default(false) @map("has_acquiring")
  hasCredit        Boolean @default(false) @map("has_credit")
  hasDeposit       Boolean @default(false) @map("has_deposit")
  hasTradeFinance  Boolean @default(false) @map("has_trade_finance")
  hasPayroll       Boolean @default(false) @map("has_payroll")
  hasCorporateCard Boolean @default(false) @map("has_corporate_card")

  // АБС-синк: дата последней синхронизации продуктов из банковской системы.
  // Когда поле заполнено, ручное изменение продуктов требует явного подтверждения
  // и логируется с признаком "manual_override".
  productSyncedAt  DateTime? @map("product_synced_at")

  notes            String?  // Свободные заметки менеджера о клиенте

  branch         Branch          @relation(fields: [branchId], references: [id])
  manager        User?           @relation("ClientManager", fields: [managerId], references: [id])
  kam            User?           @relation("ClientKAM", fields: [kamId], references: [id])
  activities     Activity[]
  tasks          Task[]
  deals          Deal[]
  changelogs     Changelog[]
  contactPersons ContactPerson[]
  accountPlan    AccountPlan?
  kycChecklist   KYCChecklist[]
  merchants      Merchant[]

  @@map("clients")
}

model ContactPerson {
  id              String   @id @default(cuid())
  clientId        String   @map("client_id")
  name            String
  role            String?
  phone           String?
  email           String?
  isDecisionMaker Boolean  @default(false) @map("is_decision_maker")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("contact_persons")
}

model AccountPlan {
  id            String    @id @default(cuid())
  clientId      String    @unique @map("client_id")
  revenueTarget Float?    @map("revenue_target")
  revenueActual Float?    @map("revenue_actual")
  nextMeeting   DateTime? @map("next_meeting")
  initiatives   String?   // JSON-encoded string[]
  updatedAt     DateTime  @updatedAt @map("updated_at")
  updatedBy     String?   @map("updated_by")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("account_plans")
}

model Activity {
  id          String       @id @default(cuid())
  clientId    String       @map("client_id")
  dealId      String?      @map("deal_id")        // привязка к сделке (опц.)
  type        ActivityType
  product     String?      // MBUSINESS | MKASSA_POS | MKASSA_QR | ACQUIRING | SALARY_PROJECT | PAYROLL | CORPORATE_CARD | CREDIT | DEPOSIT | TRADE_FINANCE
  result      String
  notes       String?
  isPlanned   Boolean      @default(false) @map("is_planned")
  completedAt DateTime?    @map("completed_at")
  performedBy String       @map("performed_by")
  performedAt DateTime     @map("performed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  client Client  @relation(fields: [clientId], references: [id])
  user   User    @relation(fields: [performedBy], references: [id])
  deal   Deal?   @relation(fields: [dealId], references: [id])

  @@map("activities")
}

model Task {
  id          String       @id @default(cuid())
  clientId    String       @map("client_id")
  triggerDay  String?      @map("trigger_day")
  assignedTo  String       @map("assigned_to")
  dueDate     DateTime     @map("due_date")
  priority    TaskPriority @default(P3)
  action      String
  result      String?
  status      TaskStatus   @default(PENDING)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])
  user   User   @relation(fields: [assignedTo], references: [id])

  @@map("tasks")
}

model Deal {
  id            String     @id @default(cuid())
  clientId      String?    @map("client_id")
  leadName      String?    @map("lead_name")
  ownerId       String     @map("owner_id")
  team          TeamType
  stage         String
  productName   String?    @map("product_name")
  amount        Float?
  probability   Int?
  expectedClose DateTime?  @map("expected_close")
  lostReason    String?          @map("lost_reason")
  lostReasonCode DealLostReason? @map("lost_reason_code")
  notes         String?
  status        DealStatus @default(ACTIVE)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  client     Client?    @relation(fields: [clientId], references: [id])
  owner      User       @relation(fields: [ownerId], references: [id])
  activities Activity[]

  @@map("deals")
}

model Changelog {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  changedBy String   @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at")
  field     String
  oldVal    String?  @map("old_val")
  newVal    String?  @map("new_val")

  client Client @relation(fields: [clientId], references: [id])
  user   User   @relation(fields: [changedBy], references: [id])

  @@map("changelogs")
}

// ─── Permission Matrix ────────────────────────────────────
// Controls which roles can see sensitive data sections.
// ADMIN always has full access (enforced in code, not stored here).

model PermissionConfig {
  id        String   @id @default(cuid())
  role      String   // 'ANALYST' | 'MANAGER' | 'KAM_ROLE'
  resource  String   // see PERMISSION_RESOURCES in src/lib/permissions.ts
  canView   Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@unique([role, resource])
  @@map("permission_configs")
}

// ─── Исторические снимки портфеля ───────────────────────────
// Ежедневный снимок агрегированных метрик.
// Захватывается автоматически при запуске CLM-синхронизации.
// team = "__all__" → все команды; "B2B" / "KM" / ... → конкретная команда.
model PortfolioSnapshot {
  id             String   @id @default(cuid())
  snapshotDate   DateTime @map("snapshot_date")   // начало дня UTC
  team           String   @default("__all__")     // "__all__" | TeamType string

  totalClients   Int      @default(0) @map("total_clients")
  activeClients  Int      @default(0) @map("active_clients")
  atRiskClients  Int      @default(0) @map("at_risk_clients")
  lapsedClients  Int      @default(0) @map("lapsed_clients")
  activationRate Float    @default(0) @map("activation_rate")  // 0–100
  activitiesWeek Int      @default(0) @map("activities_week")  // взаимодействий за 7 дней до снимка

  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([snapshotDate, team])
  @@map("portfolio_snapshots")
}

// ─── Мерчанты (MKassa терминалы) ─────────────────────────
model Merchant {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  terminalId   String   @unique @map("terminal_id")
  type         String   // POS | QR | KKM
  status       String   @default("ACTIVE")  // ACTIVE | INACTIVE | BLOCKED
  lastTxnDate  DateTime? @map("last_txn_date")
  txnCount30d  Int      @default(0) @map("txn_count_30d")
  isPhantom    Boolean  @default(false) @map("is_phantom")  // daysSinceLastTxn >= 90 AND txnCount30d = 0
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@map("merchants")
}

// ─── Ежемесячный снапшот KPI менеджера ───────────────────
model ManagerMonthlySnapshot {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  year            Int
  month           Int      // 1-12
  plannedClients  Int      @default(0) @map("planned_clients")
  actualClients   Int      @default(0) @map("actual_clients")
  activationRate  Float    @default(0) @map("activation_rate")
  activitiesCount Int      @default(0) @map("activities_count")
  activations     Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, year, month])
  @@map("manager_monthly_snapshots")
}

// ─── KYC Чеклист ─────────────────────────────────────────
model KYCChecklist {
  id         String        @id @default(cuid())
  clientId   String        @map("client_id")
  item       String        // INN_CONFIRMED | CHARTER | PASSPORT_DIRECTOR | BENEFICIAL_OWNER | TAX_REG | AML_CLEAR | ADDRESS_CONFIRMED
  status     KYCItemStatus @default(PENDING)
  note       String?
  updatedBy  String?       @map("updated_by")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, item])
  @@map("kyc_checklist")
}

// ─── КП-шаблоны (M5) ─────────────────────────────────────
model ProposalTemplate {
  id          String   @id @default(cuid())
  title       String
  team        TeamType
  productName String   @map("product_name")
  body        String   // Markdown / plain text тела КП
  tags        String?  // comma-separated tags
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("proposal_templates")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String    // task_assigned | task_overdue | task_escalated | task_completed
  title     String
  body      String    @default("")
  href      String    @default("") // URL для перехода по клику
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}
